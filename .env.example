TELEGRAM_BOT_TOKEN=
# Полный URL проекта, например: https://xxxxx.supabase.co (допустимо и без https — подставим автоматически)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_BUCKET=invoices
# Чат, куда уходят карточки новых счетов (ваш chat_id в Telegram = поле public.users.chat_id)
ACCOUNTANT_CHAT_ID=
# Имя бота без @ (для ссылок t.me/.../start=CODE) — getUpdates или @BotFather
# TELEGRAM_BOT_USERNAME=YourBot
# Опционально: таймаут сессии (мс), 0 или пусто = выкл.
# SESSION_TTL_MS=
